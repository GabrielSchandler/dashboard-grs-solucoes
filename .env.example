# Opcao simples: link direto de download do arquivo XLSX.
# Pode ser um link compartilhado do OneDrive/SharePoint que baixe o Excel.
EXCEL_DOWNLOAD_URL=

# Apenas para testar localmente. Nao configure na Vercel.
LOCAL_EXCEL_PATH=

# Opcao recomendada para SharePoint privado: Microsoft Graph.
# Crie um App Registration no Azure, adicione permissao Files.Read.All ou Sites.Read.All,
# e configure estes segredos na Vercel.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Use um destes formatos com Microsoft Graph:
GRAPH_FILE_DOWNLOAD_URL=
# Exemplo: https://graph.microsoft.com/v1.0/drives/{drive-id}/root:/PLANEJAMENTO/BASE%20DE%20VENDAS.xlsx:/content

GRAPH_DRIVE_ID=
GRAPH_FILE_PATH=
# Exemplo GRAPH_FILE_PATH: PLANEJAMENTO/BASE DE VENDAS.xlsx

# Ajustes opcionais.
DASHBOARD_META=100000
DASHBOARD_REFRESH_SECONDS=300
